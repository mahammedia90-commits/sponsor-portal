# ═══════════════════════════════════════════════════
# MAHAM EXPO — Environment Configuration
# ═══════════════════════════════════════════════════

# Database
DATABASE_URL=mysql://user:password@localhost:3306/maham_expo

# Authentication
JWT_SECRET=generate-with-openssl-rand-hex-32
OAUTH_SERVER_URL=https://auth-service-api.mahamexpo.sa

# API
API_BASE_URL=https://admin.mahamexpo.sa
EXPO_SERVICE_URL=https://expo-service-api.mahamexpo.sa/api/v1
AUTH_SERVICE_URL=https://auth-service-api.mahamexpo.sa/api/v1

# Payment
TAP_SECRET_KEY=sk_live_your_tap_key
TAP_PUBLIC_KEY=pk_live_your_tap_key

# SMS (Msegat)
MSEGAT_API_KEY=your_msegat_key
MSEGAT_USERNAME=your_msegat_username

# Server
PORT=3000
NODE_ENV=production

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=maham-expo
FIREBASE_PRIVATE_KEY=your_firebase_key
